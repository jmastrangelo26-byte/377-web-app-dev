"""
MODIFICATIONS MADE:

1. Added a "special food" (power-up) that appears randomly during gameplay.
2. The special food moves continuously across the screen in diagonal directions.
3. Movement direction changes periodically using a timer and random direction selection.
4. Special food wraps around screen boundaries instead of disappearing.
5. Implemented a spawn system that gives a small random chance for the special food to appear.
6. Added a larger hitbox (buffer zone) for the special food, making it easier to collect.
7. When collected, the special food increases the snake length by +3 instead of +1.
8. Modified the main game loop to manage power-up state, movement, and collision handling.
"""

import pygame
import time
import random
 
pygame.init()
 
# EXISTING: color definitions
white = (255, 255, 255)
yellow = (255, 255, 102)
black = (0, 0, 0)
red = (213, 50, 80)   # MODIFIED USE: also used for special food
green = (0, 255, 0)
blue = (50, 153, 213)
 
# EXISTING: display setup
dis_width = 600
dis_height = 400
 
dis = pygame.display.set_mode((dis_width, dis_height))
pygame.display.set_caption('Snake Game by Edureka')
 
clock = pygame.time.Clock()
 
snake_block = 10
snake_speed = 15
 
# EXISTING: fonts
font_style = pygame.font.SysFont("bahnschrift", 25)
score_font = pygame.font.SysFont("comicsansms", 35)
 
 
# EXISTING
def Your_score(score):
    value = score_font.render("Your Score: " + str(score), True, yellow)
    dis.blit(value, [0, 0])
 
 
# EXISTING
def our_snake(snake_block, snake_list):
    for x in snake_list:
        pygame.draw.rect(dis, black, [x[0], x[1], snake_block, snake_block])
 
 
# EXISTING
def message(msg, color):
    mesg = font_style.render(msg, True, color)
    dis.blit(mesg, [dis_width / 6, dis_height / 3])


# NEW: Determines if the power-up should spawn based on a low probability
# MODIFIES GAME FLOW: introduces randomness beyond basic food spawning
def should_spawn_power_up(power_up_exists):
    spawn_values = [10, 20]  # only spawn if random matches these values (low chance)
    if power_up_exists == False:
        
        random_value = random.randint(1, 100)

        for value in spawn_values:
            if random_value == value:
                return True

    return False
            

# NEW: Controls movement behavior of the special food
# MODIFIES GAME MECHANICS: introduces moving target instead of static object
def move_special_food(special_x, special_y, direction):

    speed = 4  # speed of movement

    # NEW: diagonal movement based on direction value
    if direction == 1:
        special_x += speed
        special_y += speed
    elif direction == 2:
        special_x -= speed
        special_y -= speed
    elif direction == 3:
        special_x += speed
        special_y -= speed
    elif direction == 4:
        special_x -= speed 
        special_y += speed

    # NEW: wrap-around logic instead of boundary collision
    if special_x >= dis_width:
        special_x = 0
    if special_x < 0:
        special_x = dis_width - snake_block
    if special_y >= dis_height:
        special_y = 0
    if special_y < 0:
        special_y = dis_height - snake_block
    
    return special_x, special_y


def gameLoop():
    direction_timer = 0  # NEW: controls how often movement direction changes

    game_over = False
    game_close = False

    # NEW: tracks whether a power-up is currently active on screen
    power_up_exists = False
    
    # NEW: position of special food
    special_x = 0
    special_y = 0

    # EXISTING: snake starting position
    x1 = dis_width / 2
    y1 = dis_height / 2
 
    x1_change = 0
    y1_change = 0
 
    # EXISTING: snake body tracking
    snake_List = []
    Length_of_snake = 1
 
    # EXISTING: normal food spawn
    foodx = round(random.randrange(0, dis_width - snake_block) / 10.0) * 10.0
    foody = round(random.randrange(0, dis_height - snake_block) / 10.0) * 10.0
 
    while not game_over:

        # NEW: periodically reset timer to control direction changes
        if direction_timer == 15:
            direction_timer = 0

        while game_close == True:
            dis.fill(blue)
            message("You Lost! Press C-Play Again or Q-Quit", red)
            Your_score(Length_of_snake - 1)
            pygame.display.update()
 
            for event in pygame.event.get():
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_q:
                        game_over = True
                        game_close = False
                    if event.key == pygame.K_c:
                        gameLoop()
 
        # EXISTING: input handling
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                game_over = True
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_LEFT:
                    x1_change = -snake_block 
                    y1_change = 0
                elif event.key == pygame.K_RIGHT:
                    x1_change = snake_block
                    y1_change = 0
                elif event.key == pygame.K_UP:
                    y1_change = -snake_block
                    x1_change = 0
                elif event.key == pygame.K_DOWN:
                    y1_change = snake_block
                    x1_change = 0

        # EXISTING: boundary check for snake
        if x1 >= dis_width or x1 < 0 or y1 >= dis_height or y1 < 0:
            game_close = True

        # EXISTING: update snake position
        x1 += x1_change
        y1 += y1_change

        # EXISTING: draw background and normal food
        dis.fill(blue)
        pygame.draw.rect(dis, green, [foodx, foody, snake_block, snake_block])
        
        # NEW: attempt to spawn special food randomly
        if should_spawn_power_up(power_up_exists):
            power_up_exists = True
            special_x = round(random.randrange(0, dis_width - snake_block) / 10.0) * 10.0
            special_y = round(random.randrange(0, dis_height - snake_block) / 10.0) * 10.0
        
        # NEW: choose a new direction at timed intervals
        if direction_timer == 0:
            direction = random.randint(1, 4)
        
        direction_timer += 1

        # NEW: draw and move special food if active
        if power_up_exists:
            pygame.draw.rect(dis, red, [special_x, special_y, snake_block, snake_block])
            special_x, special_y = move_special_food(special_x, special_y, direction)

        # NEW: expanded hitbox for easier collision with moving target
        hitbox_size = 10

        # NEW: collision detection for special food (different from exact match of normal food)
        if (x1 < (special_x + hitbox_size) and x1 > (special_x - hitbox_size)):
            if y1 < (special_y + hitbox_size) and y1 > (special_y - hitbox_size):
                power_up_collected = True  # NEW: tracks collection event
                special_x = round(random.randrange(0, dis_width - snake_block) / 10.0) * 10.0
                special_y = round(random.randrange(0, dis_height - snake_block) / 10.0) * 10.0
                power_up_exists = False  # NEW: remove power-up after collection
                Length_of_snake += 3     # MODIFIED: reward is greater than normal food

        # EXISTING: snake body update
        snake_Head = []
        snake_Head.append(x1)
        snake_Head.append(y1)
        snake_List.append(snake_Head)

        if len(snake_List) > Length_of_snake:
            del snake_List[0]
 
        # EXISTING: self-collision detection
        for x in snake_List[:-1]:
            if x == snake_Head:
                game_close = True
 
        # EXISTING: render snake and score
        our_snake(snake_block, snake_List)
        Your_score(Length_of_snake - 1)
 
        pygame.display.update()
 
        # EXISTING: normal food collision (exact match)
        if x1 == foodx and y1 == foody:
            foodx = round(random.randrange(0, dis_width - snake_block) / 10.0) * 10.0
            foody = round(random.randrange(0, dis_height - snake_block) / 10.0) * 10.0
            Length_of_snake += 1

        clock.tick(snake_speed)
 
    
    pygame.quit()
    quit()
 
gameLoop()